{
  "name": "jarvis",
  "private": true,
  "version": "0.1.0",
  "description": "Jarvis - resident Windows voice assistant (monorepo root)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/app",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "fetch-models": "node scripts/fetch-models.js"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "@types/node": "^26.1.1"
  }
}
