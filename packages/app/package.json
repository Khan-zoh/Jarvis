{
  "name": "@jarvis/app",
  "productName": "Jarvis",
  "private": true,
  "version": "0.1.0",
  "description": "Jarvis resident Windows voice assistant",
  "author": "Jarvis contributors",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && electron-vite build",
    "test": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && vitest run"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "electron": "43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "5.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.217",
    "@jarvis/tools-mcp": "0.1.0",
    "@openai/codex-sdk": "^0.144.5",
    "onnxruntime-node": "1.21.1"
  }
}
