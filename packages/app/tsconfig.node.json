{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node"],
    "noEmit": true,
    // Typecheck the workspace import against tools-mcp SOURCE (dist may not exist yet during a
    // clean-tree typecheck); at runtime Node resolves the same specifier to the built
    // dist/google/auth.js via the tools-mcp `exports` map (electron-vite externalizes it as a
    // regular dependency — see the googleapis-inlining note in cdd/tasks/wire-and-converse.md).
    "paths": {
      "@jarvis/tools-mcp/google/auth": ["../tools-mcp/src/google/auth.ts"],
      "@jarvis/tools-mcp/loader": ["../tools-mcp/src/loader.ts"],
      "@jarvis/tools-mcp/pluginConfig": ["../tools-mcp/src/pluginConfig.ts"],
      "@jarvis/tools-mcp/brain/store": ["../tools-mcp/src/brain/store.ts"],
      "@jarvis/tools-mcp/brain/embedder": ["../tools-mcp/src/brain/embedder.ts"],
      "@jarvis/tools-mcp/brain/types": ["../tools-mcp/src/brain/types.ts"]
    }
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/agents/**/*.ts",
    "src/voice/**/*.ts",
    "src/shared/**/*.ts",
    "test/**/*.ts",
    "electron.vite.config.ts",
    "vitest.config.ts",
    // The brain store (imported via the workspace path map for typecheck) imports the
    // untyped `better-sqlite3`; pull in tools-mcp's ambient declaration for it.
    "../tools-mcp/src/brain/betterSqlite3.d.ts"
  ],
  "exclude": [
    "test/overlay-view.test.ts",
    "test/main-view.test.ts",
    "test/settings.test.ts",
    "test/brain-ui.test.ts"
  ]
}
